
# Secrets — never commit these
backend/.env
.env
.env.local
.env.production

# Python
__pycache__/
*.py[cod]
*.pyo
.coverage
.coverage.*
htmlcov/
.pytest_cache/
*.egg-info/
dist/
build/
.venv/
venv/

# Database files
*.db

# Uploaded media files — keep directory structure but ignore content
backend/app/media/tmp/audio/*
!backend/app/media/tmp/audio/.gitkeep
backend/app/media/tmp/images/*
!backend/app/media/tmp/images/.gitkeep
backend/app/media/tmp/documents/*
!backend/app/media/tmp/documents/.gitkeep

# Node.js / Frontend
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Audio/video uploads (should use cloud storage in prod)
*.wav
*.mp3

# Editor
.idea/
.vscode/
*.swp
*.swo
*~
