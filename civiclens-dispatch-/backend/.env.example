# .env.example
#
# Template for production environment variables.
# THIS FILE IS SAFE TO COMMIT — it has no real secrets, only placeholders.
#
# HOW TO USE:
#   When deploying (Day 68), copy these variable names into your server's
#   environment variable settings (Render dashboard, Railway dashboard, etc.)
#   and fill in the real values there.
#
#   NEVER put real passwords, tokens, or URLs in a file you commit to Git.
#   The real values live only on the server, set through the hosting dashboard.
#
# Day 67: Production configuration template

# ----------------------------------------
# AUTH (Day 72)
# JWT signing secret — generate with: openssl rand -hex 32
# NEVER use the dev default in production.
# ----------------------------------------
SECRET_KEY=replace-with-openssl-rand-hex-32-output

# ----------------------------------------
# ENVIRONMENT
# Tells the app it's running in production mode.
# This single variable changes: debug off, WARNING logs, strict CORS,
# 4 workers, no auto-reload.
# ----------------------------------------
ENVIRONMENT=production

# ----------------------------------------
# DATABASE
# Replace with your actual Supabase (or other PostgreSQL) connection string.
# Format: postgresql+asyncpg://user:password@host:port/database
#
# Where to get this:
#   Supabase → Project Settings → Database → Connection String → URI
#   Change "postgres://" to "postgresql+asyncpg://"
# ----------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ----------------------------------------
# HUGGING FACE
# Your Hugging Face API token.
# Get it from: huggingface.co/settings/tokens
# ----------------------------------------
HUGGINGFACE_API_TOKEN=hf_your_token_here

# ----------------------------------------
# CORS
# The URL of your deployed frontend (Vercel, Netlify, etc.)
# Only requests from this URL will be allowed by the API.
# No trailing slash.
# ----------------------------------------
CORS_ORIGINS=https://your-app.vercel.app

# ----------------------------------------
# APP INFO
# Update version when you make significant changes.
# ----------------------------------------
APP_NAME=CivicLens Dispatch API
APP_VERSION=1.0.0

# ----------------------------------------
# FILE UPLOADS
# In production, you might point this to a cloud storage mount.
# For now, local storage is fine for a portfolio project.
# ----------------------------------------
UPLOAD_DIR=app/media/tmp
MAX_FILE_SIZE=10485760