# backend/.env.example
# Template for environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file — it contains secrets!
# .env is listed in .gitignore to prevent accidental commits.
#
# Day 57: Complete configuration template

# ============================================================
# APPLICATION
# ============================================================

# Application name (shown in API docs and health check)
APP_TITLE=CivicLens Dispatch API

# Version string
VERSION=1.0.0

# Debug mode: true = development, false = production
# When true: detailed error messages, auto-reload enabled
# When false: generic error messages, optimized for performance
DEBUG=true

# Environment: development, staging, or production
ENVIRONMENT=development

# ============================================================
# DATABASE
# ============================================================

# Async database URL (used for all queries)
# Development (SQLite — no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./test.db

# Production (PostgreSQL — requires a running PostgreSQL server):
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/civiclens

# ============================================================
# AI / HUGGING FACE
# ============================================================

# Your Hugging Face API token
# Get one at: https://huggingface.co/settings/tokens
# Required for AI features (transcription, classification, summarization, risk scoring)
HUGGINGFACE_API_KEY=hf_your_token_here

# Use mock AI services instead of real API calls (for testing)
# Set to true if you don't have a Hugging Face token or want faster testing
USE_MOCK_AI=false

# ============================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================

# Allowed frontend origins (comma-separated)
# Development: * allows any origin
# Production: set to your actual frontend URL
CORS_ORIGINS=*

# Examples for production:
# CORS_ORIGINS=https://civiclens.example.com
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# ============================================================
# FILE UPLOADS
# ============================================================

# Directory for uploaded media files (audio, images)
UPLOAD_DIR=backend/app/media/tmp

# Maximum upload file size in bytes (default: 10 MB)
MAX_UPLOAD_SIZE=10485760

# ============================================================
# LOGGING
# ============================================================

# Minimum log level: DEBUG, INFO, WARNING, ERROR
# Development: INFO (shows operational events)
# Production: WARNING (reduces noise, only shows problems)
LOG_LEVEL=INFO