# ==========================================
# CivicLens Dispatch - Environment Variables
# ==========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# Environment
ENVIRONMENT=development
DEBUG=True

# PostgreSQL Database
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_DB=civiclens
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full Database URL (auto-constructed from above, or specify directly)
DATABASE_URL=postgresql+asyncpg://your_username:your_password@localhost/civiclens

# File Storage
UPLOAD_DIR=backend/app/media/tmp
MAX_UPLOAD_SIZE=10485760

# API Keys (add when you register for services)
# MAPBOX_API_KEY=your_mapbox_key_here
# HUGGINGFACE_API_KEY=your_huggingface_key_here

# Security
SECRET_KEY=change-this-to-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30