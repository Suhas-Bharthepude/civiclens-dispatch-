# backend/.dockerignore
#
# Tells Docker which files to EXCLUDE when copying the project into the image.
# Works exactly like .gitignore.
#
# Without this file Docker copies EVERYTHING — including your .venv
# (hundreds of MB), .env (your secrets), and test databases.
# This file keeps the image small and secrets-free.
#
# Day 68: Docker containerization

# ============================================================
# SECRETS — never bake these into an image
# If an image with your .env gets pushed to a registry,
# your API token is exposed to anyone who pulls it.
# ============================================================

.env
.env.local
.env.production

# ============================================================
# VIRTUAL ENVIRONMENT
# Docker installs packages fresh via pip using requirements.txt.
# The .venv folder is hundreds of MB and is not needed in the image.
# ============================================================

.venv
venv
env

# ============================================================
# GIT HISTORY
# Version control files are not needed to run the app.
# ============================================================

.git
.gitignore
.gitattributes

# ============================================================
# PYTHON CACHE
# Auto-generated at runtime — don't bake stale ones in.
# ============================================================

__pycache__
*.pyc
*.pyo
*.pyd

# ============================================================
# TEST FILES
# Tests don't run inside the production container.
# ============================================================

scripts/test_*.py
.pytest_cache
.coverage
htmlcov/

# ============================================================
# DATABASES
# The container creates its own fresh database on first run.
# ============================================================

test.db
*.db

# ============================================================
# UPLOADED MEDIA
# Don't bake test uploads into the image.
# Real uploads happen at runtime and are persisted via volumes.
# The Dockerfile creates the empty directories separately.
# ============================================================

app/media/tmp/

# ============================================================
# EDITOR AND OS FILES
# ============================================================

.vscode/
.DS_Store
*.egg-info/
dist/
build/

# NOTE: Do NOT ignore requirements.txt — the Dockerfile needs it.