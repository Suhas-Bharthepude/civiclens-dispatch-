# PostgreSQL username
POSTGRES_USER=civic_user

# PostgreSQL password
POSTGRES_PASSWORD=secret123

# PostgreSQL database name
POSTGRES_DB=civiclens

# PostgreSQL host (local machine)
POSTGRES_HOST=localhost

# PostgreSQL port (default is 5432)
# PostgreSQL port which is a virtual endpoint that acts as a specific doorway through which client applications 
# (like a web app or an admin tool) communicate with the PostgreSQL database server 
POSTGRES_PORT=5432

# Full connection string for async database usage
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db_name> tells SQLAlchemy/Databases to use async PostgreSQL driver.
# civic_user:12345 is the user/password I created
# localhost/civic_db is my local database
DATABASE_URL=postgresql+asyncpg://civic_user:12345@localhost/civic_db 


# postgresql+asyncpg://  tells SQLAlchemy to use PostgreSQL with the async driver asyncpg.
# civic_user:12345  PostgreSQL username and password.
# localhost:5432  PostgreSQL host and port (default for local PostgreSQL).
# civic_db the database we created.
# This .env file is read by dotenv in the code.

# asyncpg is the async driver used by databases.Database.
# psycopg2-binary is the sync driver SQLAlchemy uses for table creation.
